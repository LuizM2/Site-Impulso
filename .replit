entrypoint = "index.html"
modules = ["python-3.11"]

[nix]
channel = "stable-24_11"
packages = ["static-web-server"]

[deployment]
publicDir = "public"
deploymentTarget = "static"
build = ["rm -rf public && mkdir -p public && cp -r index.html politica_privacidade.html termos_de_uso.html style.css script.js favicon.png images/ public/"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "ImpulsoTech Website"

[[workflows.workflow]]
name = "ImpulsoTech Website"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[agent]
expertMode = true
