entrypoint = "index.html"
modules = ["python-3.11"]

[nix]
channel = "stable-24_11"
packages = ["static-web-server"]

[deployment]
publicDir = "public"
deploymentTarget = "static"
build = ["bash", "-c", "rm -rf public && mkdir -p public && cp -r index.html politica_privacidade.html termos_de_uso.html style.css script.js favicon.png images/ public/"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "ImpulsoTech Website"

[[workflows.workflow]]
name = "ImpulsoTech Website"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 -m http.server 5000 --bind 0.0.0.0"
waitForPort = 5000

[agent]
expertMode = true

[[ports]]
localPort = 5000
externalPort = 80
