entrypoint = "index.html"
modules = ["python-3.11"]

[nix]
channel = "stable-24_11"
packages = ["static-web-server"]

[deployment]
publicDir = "public"
deploymentTarget = "static"
build = ["bash", "-c", "rm -rf public && mkdir -p public && cp -r *.html *.css *.js *.png images/ public/ 2>/dev/null; true"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "ImpulsoTech Website"

[[workflows.workflow]]
name = "ImpulsoTech Website"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "static-web-server --host 0.0.0.0 --port 5000 --root ."
waitForPort = 5000

[agent]
expertMode = true

[[ports]]
localPort = 5000
externalPort = 80
